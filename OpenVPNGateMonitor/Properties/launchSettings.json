        "OPEN_VPN_BACKGROUND_SERVICE_DISABLED": "true"
      }
    },
    "OpenVPNGateMonitor Release": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "https://0.0.0.0:5581;http://0.0.0.0:5581",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Release",
        "OPEN_VPN_BACKGROUND_SERVICE_DISABLED": "true"
      }
    }
  }
}
