{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "OpenVPNGateMonitor Development": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "launchUrl": "swagger",
      "applicationUrl": "http://0.0.0.0:5581",
