<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFrameworks>net10.0;net8.0;net9.0</TargetFrameworks>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>14</LangVersion>

        <!-- NuGet package metadata -->
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <PackageId>DataGateMonitor.SharedModels</PackageId>
        <Authors>imkolganov</Authors>
        <Product>DataGateMonitor</Product>
        <AssemblyTitle>DataGateMonitor API contracts (DataGateMonitor.SharedModels)</AssemblyTitle>
        <Description>HTTP API contracts for the DataGateMonitor backend (DataGateMonitorBackend).</Description>
        <Title>DataGateMonitor — DataGateMonitor.SharedModels</Title>
        <RepositoryUrl>https://github.com/IMKolganov/DataGateMonitorBackend</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <Copyright>DataGateMonitor</Copyright>
        <PackageProjectUrl>https://github.com/IMKolganov/DataGateMonitorBackend</PackageProjectUrl>
        <PackageTags>#DataGateMonitor #OpenVpn #GateMonitor #Dashboard</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <!-- Backend consumes this library via NuGet (PackageReference) only. Bump <Version>, publish, then bump PackageReference in consuming projects. -->
        <Version>1.0.7</Version>
        <AssemblyVersion>1.0.7.0</AssemblyVersion>
        <FileVersion>1.0.7.0</FileVersion>
        <PackageIcon>favicon.png</PackageIcon>

        <Deterministic>true</Deterministic>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>

        <IncludeSymbols>true</IncludeSymbols>
        <IncludeSource>true</IncludeSource>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <SignAssembly>false</SignAssembly>
        <PublicSign>false</PublicSign>
        <IsPackable>true</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <None Include="README.md" Pack="true" PackagePath="">
            <CopyToOutputDirectory>Always</CopyToOutputDirectory>
        </None>

        <None Include="favicon.png" Pack="true" PackagePath="\" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Microsoft.AspNetCore.Mvc.Core" Version="2.3.9" />
      <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" Version="10.0.7" />
      <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    </ItemGroup>

</Project>