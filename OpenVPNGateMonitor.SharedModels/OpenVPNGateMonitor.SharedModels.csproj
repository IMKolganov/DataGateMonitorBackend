<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>13</LangVersion>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <Title>DashBoard OpenVpn Gate Moniotor SharedModels</Title>
        <RepositoryUrl>https://github.com/IMKolganov/OpenVPNGateMonitor</RepositoryUrl>
        <Copyright>OpenVPNGateMonitor</Copyright>
        <PackageProjectUrl>https://github.com/IMKolganov/OpenVPNGateMonitor</PackageProjectUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>#OpenVPNGateMonitor #OpenVpn #GateMonitor #Dashboard</PackageTags>
    </PropertyGroup>

    <ItemGroup>
      <Folder Include="Auth\Requests\" />
      <Folder Include="OpenVpnWebSocket\Mappings\" />
      <Folder Include="OpenVpnWebSocket\Responses\" />
      <Folder Include="Requests\" />
      <Folder Include="Settings\Mappings\" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Mapster" Version="7.4.0" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\OpenVPNGateMonitor.Models\OpenVPNGateMonitor.Models.csproj" />
    </ItemGroup>

</Project>
